PARALLAX_AUDIT_DIR=/data/audits
PARALLAX_HOST=0.0.0.0
PARALLAX_PORT=8787

# Create the hashed config before serving:
# npm run beta-init -- --audit-dir "$PARALLAX_AUDIT_DIR" --api-token "$PARALLAX_BETA_API_TOKEN"
PARALLAX_BETA_API_TOKEN=replace-with-secret-manager-value

# Optional when system python3 is not the desired analytics runtime.
# PARALLAX_PYTHON=/usr/bin/python3
